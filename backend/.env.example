# Hugging Face Configuration
# Get your token from: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# Recommended free models (no authentication required for some):
# - mistralai/Mistral-7B-Instruct-v0.2 (good balance, fast)
# - google/flan-t5-large (smaller, very fast)
# - microsoft/phi-2 (efficient, good quality)
# - meta-llama/Llama-2-7b-chat-hf (requires token)
HF_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# Backend Configuration
BACKEND_URL=http://localhost:8000
